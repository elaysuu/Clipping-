{
  "name": "clipfarm",
  "version": "0.1.0",
  "description": "Universal clipping engine — pay-per-view campaign clips, zero-budget toolchain.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "clip": "bin/clip.js"
  },
  "scripts": {
    "clip": "node bin/clip.js",
    "radar": "node bin/radar.js",
    "test": "node --test tests/*.test.js",
    "dashboard": "node bin/dashboard.js",
    "sync": "node bin/sync.js",
    "run": "node bin/run.js",
    "report": "node bin/report.js",
    "worker": "node bin/worker.js"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  }
}
